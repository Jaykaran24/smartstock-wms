# Docker Ignore File
# Exclude files and directories from Docker build context

# Node modules
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment files
.env
.env.local
.env.*.local
.env.production
.env.development

# Logs
logs/
*.log

# Backups
backups/

# Uploads
uploads/

# Git
.git/
.gitignore

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Test
coverage/
.nyc_output/

# Documentation (uncomment if needed)
# README.md
# docs/

# Docker files (to avoid recursion)
Dockerfile
Dockerfile.dev
docker-compose.yml
docker-compose.dev.yml
.dockerignore

# CI/CD
.github/
.gitlab-ci.yml

# Temporary files
tmp/
temp/
*.tmp
