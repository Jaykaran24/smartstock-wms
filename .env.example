# Environment Configuration
NODE_ENV=development

# Server Configuration
PORT=5000
FRONTEND_URL=http://localhost:5000

# Database Configuration
# Replace with your MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://Admin:Admin2435@cluster0.3ie2r5o.mongodb.net/smartstock-wms?retryWrites=true&w=majority

# JWT Configuration
# Generate a strong secret key (minimum 32 characters)
JWT_SECRET=your-super-secure-jwt-secret-key-minimum-32-characters-long
JWT_REFRESH_SECRET=your-super-secure-refresh-secret-key-minimum-32-characters-long

# Default Admin Configuration
# This creates a default admin user on first startup
DEFAULT_ADMIN_PASSWORD=Admin123!

# Rate Limiting Configuration
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=10

# Security Configuration
BCRYPT_ROUNDS=12

# Logging Configuration
LOG_LEVEL=info
LOG_FILE=logs/app.log

# Email Configuration (Optional - for future features)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@smartstock.com

# File Upload Configuration (Optional)
MAX_FILE_SIZE=10485760
UPLOAD_PATH=uploads/

# Backup Configuration (Optional)
BACKUP_ENABLED=false
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30

# Performance Configuration
MONGODB_POOL_SIZE=10
REQUEST_TIMEOUT=30000

# Features Toggle (Optional)
ENABLE_EMAIL_NOTIFICATIONS=false
ENABLE_SMS_NOTIFICATIONS=false
ENABLE_ANALYTICS=true