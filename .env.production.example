# Environment Configuration for Production
NODE_ENV=production

# Server Configuration
PORT=3000
FRONTEND_URL=https://yourdomain.com

# Database Configuration
# Use your production MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/smartstock-wms?retryWrites=true&w=majority

# JWT Configuration
# IMPORTANT: Generate new secure keys for production
# Use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_SECURE_RANDOM_STRING_MINIMUM_64_CHARACTERS
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_SECURE_RANDOM_STRING_MINIMUM_64_CHARACTERS

# Default Admin Configuration
# Change this password immediately after first login
DEFAULT_ADMIN_PASSWORD=ChangeMe123!SecurePassword

# Rate Limiting Configuration
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=5

# Security Configuration
BCRYPT_ROUNDS=12

# Logging Configuration
LOG_LEVEL=info
LOG_FILE=logs/app.log

# Email Configuration (Optional - configure if needed)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password
FROM_EMAIL=noreply@smartstock.com

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_PATH=uploads/

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30

# Performance Configuration
MONGODB_POOL_SIZE=10

# CORS Configuration (comma-separated allowed origins)
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Session Configuration
SESSION_SECRET=REPLACE_WITH_SECURE_RANDOM_STRING

# SSL/TLS Configuration (if using HTTPS)
SSL_KEY_PATH=/path/to/ssl/privkey.pem
SSL_CERT_PATH=/path/to/ssl/fullchain.pem

# Monitoring & Analytics (Optional)
SENTRY_DSN=
NEW_RELIC_LICENSE_KEY=
GOOGLE_ANALYTICS_ID=
